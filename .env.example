# Environment Variables Template — Artificial Teacher v2.0

# ── Telegram ───────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
OWNER_ID=your_telegram_user_id
BOT_USERNAME=@Artificial_teacher_bot

# ── Database ───────────────────────────────────────────────
DB_PATH=data/engbot.db

# ── AI ─────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxx
OPENAI_API_KEY=sk-xxxxx
AI_MODEL=openai/gpt-4o-mini
AI_CONCURRENCY=6
AI_TIMEOUT=30
AI_MAX_RETRIES=2

# ── TTS (TopMediaI) ───────────────────────────────────────
TOPMEDIAI_API_KEY=your_topmediai_key_here
TOPMEDIAI_API_BASE=https://api.topmediai.com/v1
TTS_CONCURRENCY=3

# ── FastAPI ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080

# ── URLs ───────────────────────────────────────────────────
WEB_APP_URL=https://your-webapp-url.vercel.app
WEB_APP_URL_FREE=
WEB_APP_URL_STANDARD=
WEB_APP_URL_PRO=
WEB_APP_URL_PREMIUM=
MATERIALS_URL=
MATERIALS_URL_FREE=
MATERIALS_URL_STANDARD=
MATERIALS_URL_PRO=
MATERIALS_URL_PREMIUM=
WEBHOOK_URL=
SUPPORT_URL=https://t.me/your_support
WEBSITE_URL=https://your-website.com
CHANNEL_URL=https://t.me/your_channel
INSTAGRAM_URL=https://instagram.com/your_page

# ── Telegram Channels (for inline caching) ─────────────────
INLINE_HTML_CHANNEL=0
INLINE_AUDIO_CHANNEL=0

# ── Performance ────────────────────────────────────────────
UPDATE_CONCURRENCY=12
TG_CONNECTION_POOL=12
